<%- include("partials/header.ejs") %>
<%- include("partials/navbar.ejs") %>

<link rel="stylesheet" href="/styles/CamRover.css">

<main class="camrover-page-container">
  <div class="camrover-header glass-panel">
    <h1>HISTORIC APOD <span class="text-gradient">ARCHIVES</span></h1>
    <p>Curated archive of milestone astronomy pictures of the day from NASA telescopes and observatories.</p>
    
    <div class="search-filter-box">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" id="camSearchInput" placeholder="Search archive title, observatory, or year..." onkeyup="filterCameraTable()" class="form-control">
    </div>
  </div>

  <div class="table-card glass-panel">
    <table class="cam-table" id="camTable">
      <thead>
        <tr>
          <th>Date</th>
          <th>Astronomy Discovery Title</th>
          <th>Observatory / Telescope</th>
          <th class="marker-col">Action</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="abbr-cell">2025-04-21</td><td>Galaxy Lenses Galaxy from Webb</td><td>James Webb Space Telescope (JWST)</td><td class="check-cell"><a href="/search?mode=random" class="btn-secondary" style="padding: 4px 10px; font-size: 0.8rem;">View</a></td></tr>
        <tr><td class="abbr-cell">2024-02-14</td><td>The Rosette Nebula in Hydrogen and Oxygen</td><td>Hubble Space Telescope (HST)</td><td class="check-cell"><a href="/search?mode=random" class="btn-secondary" style="padding: 4px 10px; font-size: 0.8rem;">View</a></td></tr>
        <tr><td class="abbr-cell">2023-08-15</td><td>In the Heart of the Tarantula Nebula</td><td>Hubble & ESO New Tech Telescope</td><td class="check-cell"><a href="/search?mode=random" class="btn-secondary" style="padding: 4px 10px; font-size: 0.8rem;">View</a></td></tr>
        <tr><td class="abbr-cell">2023-05-12</td><td>Pillars of Creation from James Webb</td><td>James Webb Space Telescope (JWST)</td><td class="check-cell"><a href="/search?mode=random" class="btn-secondary" style="padding: 4px 10px; font-size: 0.8rem;">View</a></td></tr>
        <tr><td class="abbr-cell">2023-01-05</td><td>The Carina Nebula Cosmic Cliffs</td><td>James Webb Space Telescope (JWST)</td><td class="check-cell"><a href="/search?mode=random" class="btn-secondary" style="padding: 4px 10px; font-size: 0.8rem;">View</a></td></tr>
        <tr><td class="abbr-cell">2022-11-20</td><td>Jupiter Auroras in Infrared</td><td>James Webb Space Telescope (JWST)</td><td class="check-cell"><a href="/search?mode=random" class="btn-secondary" style="padding: 4px 10px; font-size: 0.8rem;">View</a></td></tr>
      </tbody>
    </table>
  </div>
</main>

<script>
  function filterCameraTable() {
    const input = document.getElementById('camSearchInput');
    const filter = input.value.toUpperCase();
    const table = document.getElementById('camTable');
    const tr = table.getElementsByTagName('tr');

    for (let i = 1; i < tr.length; i++) {
      const tdDate = tr[i].getElementsByTagName('td')[0];
      const tdTitle = tr[i].getElementsByTagName('td')[1];
      const tdObs = tr[i].getElementsByTagName('td')[2];
      if (tdDate || tdTitle || tdObs) {
        const txtValueDate = tdDate.textContent || tdDate.innerText;
        const txtValueTitle = tdTitle.textContent || tdTitle.innerText;
        const txtValueObs = tdObs.textContent || tdObs.innerText;
        if (
          txtValueDate.toUpperCase().indexOf(filter) > -1 ||
          txtValueTitle.toUpperCase().indexOf(filter) > -1 ||
          txtValueObs.toUpperCase().indexOf(filter) > -1
        ) {
          tr[i].style.display = '';
        } else {
          tr[i].style.display = 'none';
        }
      }
    }
  }
</script>

<%- include("partials/footer.ejs") %>
